# Copy this file to .env and fill in real values for local development.
# Never commit the real .env file.

# --- App ---
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
# Comma-separated list of origins allowed to call this API
CORS_ORIGINS=http://localhost:5173

# --- Database ---
# A plain postgresql:// URL works (e.g. what Render's managed Postgres gives
# you) - the app derives the asyncpg driver for itself and psycopg2 for
# Alembic from this single value. An explicit postgresql+asyncpg:// URL also
# works if you prefer to be explicit locally.
DATABASE_URL=postgresql://aiws:aiws_local_password@localhost:5432/ai_workflow_studio

# --- Auth (Clerk) ---
# The backend only verifies session JWTs against Clerk's JWKS - it never
# calls the Clerk API directly, so no secret/publishable key is needed here
# (those belong in the frontend's .env instead).
# Found in Clerk Dashboard -> API Keys -> JWKS URL
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev

# --- OpenAI ---
OPENAI_API_KEY=sk-placeholder
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- File storage ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20
