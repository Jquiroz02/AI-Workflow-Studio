# Copy this file to .env and fill in real values for local development.
# Never commit the real .env file.
# Vite only exposes variables prefixed with VITE_ to client code.

VITE_API_BASE_URL=http://localhost:8000/api/v1
# Replace with your own key from the Clerk Dashboard -> API Keys.
# This placeholder is structurally valid (won't crash ClerkProvider on boot)
# but points at a fake instance, so sign-in/sign-up won't actually work.
